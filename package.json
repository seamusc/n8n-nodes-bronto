{
	"name": "@brontoio/n8n-nodes-bronto",
	"version": "0.1.1",
	"description": "n8n community node for Bronto.io log management API",
	"license": "MIT",
	"homepage": "",
	"keywords": [
		"n8n-community-node-package"
	],
	"author": {
		"name": "Seamus Cawley",
		"email": "seamus@bronto.io"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/seamusc/n8n-nodes-bronto.git"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"test": "jest",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/BrontoApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Bronto/Bronto.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"@types/jest": "^29.0.0",
		"eslint": "9.32.0",
		"jest": "^29.0.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"ts-jest": "^29.0.0",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
